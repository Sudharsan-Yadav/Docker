<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>ShopEase v2 | Modern Store</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    body {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: #222;
      min-height: 100vh;
    }

    /* Navbar */
    header {
      position: sticky;
      top: 0;
      z-index: 10;
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(12px);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 40px;
      color: white;
    }

    header h1 {
      font-weight: 700;
      letter-spacing: 1px;
    }

    .cart {
      font-size: 18px;
      background: rgba(255,255,255,0.25);
      padding: 8px 16px;
      border-radius: 30px;
      cursor: pointer;
    }

    /* Hero Section */
    .hero {
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 80px 20px;
      color: white;
    }

    .hero-content {
      max-width: 700px;
    }

    .hero h2 {
      font-size: 48px;
      margin-bottom: 15px;
    }

    .hero p {
      font-size: 18px;
      opacity: 0.9;
    }

    /* Product Grid */
    .products {
      padding: 60px 40px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 35px;
    }

    .product {
      background: rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(14px);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
      transition: transform 0.4s, box-shadow 0.4s;
    }

    .product:hover {
      transform: translateY(-12px) scale(1.02);
      box-shadow: 0 18px 40px rgba(0,0,0,0.35);
    }

    .product img {
      width: 100%;
      height: 220px;
      object-fit: cover;
    }

    .product-content {
      padding: 20px;
      color: white;
    }

    .product-content h3 {
      font-size: 20px;
      margin-bottom: 8px;
    }

    .product-content p {
      font-size: 14px;
      opacity: 0.85;
      margin-bottom: 10px;
    }

    .price {
      font-size: 20px;
      font-weight: 600;
      margin-bottom: 15px;
      color: #ffeb3b;
    }

    .product-content button {
      width: 100%;
      padding: 12px;
      border: none;
      border-radius: 30px;
      background: linear-gradient(135deg, #ff9966, #ff5e62);
      color: white;
      font-size: 15px;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .product-content button:hover {
      transform: scale(1.05);
      box-shadow: 0 6px 15px rgba(0,0,0,0.3);
    }

    /* Footer */
    footer {
      text-align: center;
      padding: 25px;
      color: rgba(255,255,255,0.7);
      font-size: 14px;
    }

    @media (max-width: 600px) {
      .hero h2 {
        font-size: 34px;
      }
    }
  </style>
</head>
<body>

  <!-- Header -->
  <header>
    <h1>🛍️ ShopEase</h1>
    <div class="cart">Cart: <span id="cartCount">0</span></div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <h2>Discover Products You’ll Love</h2>
      <p>Premium quality, modern style, and seamless shopping experience.</p>
    </div>
  </section>

  <!-- Products -->
  <section class="products">

    <div class="product">
      <img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9">
      <div class="product-content">
        <h3>Smartphone Pro</h3>
        <p>Fast. Sleek. Powerful.</p>
        <div class="price">₹29,999</div>
        <button onclick="addToCart()">Add to Cart</button>
      </div>
    </div>

    <div class="product">
      <img src="https://images.unsplash.com/photo-1585386959984-a41552231693">
      <div class="product-content">
        <h3>Premium Headset</h3>
        <p>Noise‑cancelling comfort</p>
        <div class="price">₹4,299</div>
        <button onclick="addToCart()">Add to Cart</button>
      </div>
    </div>

    <div class="product">
      <img src="https://images.unsplash.com/photo-1583394838336-acd977736f90">
      <div class="product-content">
        <h3>Running Shoes</h3>
        <p>Designed for performance</p>
        <div class="price">₹3,199</div>
        <button onclick="addToCart()">Add to Cart</button>
      </div>
    </div>

    <div class="product">
      <img src="https://images.unsplash.com/photo-1503602642458-232111445657">
      <div class="product-content">
        <h3>Smart Camera</h3>
        <p>Capture every moment</p>
        <div class="price">₹42,500</div>
        <button onclick="addToCart()">Add to Cart</button>
      </div>
    </div>

  </section>

  <!-- Footer -->
  <footer>
    © 2026 ShopEase v2 • Designed with ❤️
  </footer>

  <!-- JavaScript -->
  <script>
    let cart = 0;

    function addToCart() {
      cart++;
      document.getElementById("cartCount").innerText = cart;
      alert("✅ Added to cart successfully!");
    }
  </script>

</body>
</html>
